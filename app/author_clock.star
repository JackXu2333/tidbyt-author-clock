load("render.star", "render")
load("time.star", "time")

DEFAULT_TZ = "America/New_York"

def _pad(n):
    if n < 10:
        return "0" + str(n)
    return str(n)

def main(config):
    tz = config.get("timezone", DEFAULT_TZ)

    time_override = config.get("time", "")
    if len(time_override) == 5:
        hour = int(time_override[0:2])
        minute = int(time_override[3:5])
    else:
        now = time.now().in_location(tz)
        hour = now.hour
        minute = now.minute

    key = _pad(hour) + "_" + _pad(minute)

    entries = QUOTES.get(key, [])

    if len(entries) == 0:
        return render.Root(
            child = render.Box(
                width = 64,
                height = 32,
                child = render.Text(
                    content = str(hour) + ":" + _pad(minute),
                    font = "CG-pixel-3x5-mono",
                    color = "#FFD700",
                ),
            ),
        )

    entry = entries[0]
    before = entry["b"]
    time_case = entry["t"]
    after = entry["a"]
    author = entry["au"]

    quote_children = []

    if len(before) > 0:
        quote_children.append(
            render.WrappedText(
                content = before,
                font = "CG-pixel-3x5-mono",
                color = "#ffffff",
                width = 64,
                linespacing = 2,
            ),
        )
        quote_children.append(render.Box(width=64, height=6, color="#000000"))

    quote_children.append(
        render.WrappedText(
            content = time_case,
            font = "CG-pixel-3x5-mono",
            color = "#FFD700",
            width = 64,
            linespacing = 2,
        ),
    )

    if len(after) > 0:
        quote_children.append(render.Box(width=64, height=6, color="#000000"))
        quote_children.append(
            render.WrappedText(
                content = after,
                font = "CG-pixel-3x5-mono",
                color = "#aaaaaa",
                width = 64,
                linespacing = 2,
            ),
        )

    return render.Root(
        delay = 150,
        child = render.Column(
            children = [
                render.Marquee(
                    scroll_direction = "vertical",
                    height = 25,
                    child = render.Column(
                        children = quote_children,
                    ),
                ),
                render.Box(
                    width = 64,
                    height = 1,
                    color = "#333333",
                ),
                render.Marquee(
                    scroll_direction = "horizontal",
                    width = 64,
                    child = render.Text(
                        content = "\u2014 " + author,
                        font = "CG-pixel-3x5-mono",
                        color = "#888888",
                    ),
                ),
            ],
        ),
    )
